---
import { Image } from 'astro:assets';
import type { Service } from '../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;
---

<article class="card">
  <a class="card__media" href={`/services/${service.slug}`} aria-label={service.title}>
    <Image
      src={service.image}
      alt={service.imageAlt}
      width={480}
      height={360}
      widths={[240, 360, 480]}
      sizes="(max-width: 640px) 90vw, 300px"
    />
    <span class="card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={service.icon} /></svg>
    </span>
  </a>
  <div class="card__body">
    <h3>{service.title}</h3>
    <p class="card__summary">{service.summary}</p>
    <a class="card__link" href={`/services/${service.slug}`}>
      En savoir plus
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</article>
