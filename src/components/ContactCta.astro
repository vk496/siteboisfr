---
import { site } from '../config/site';
const primaryPhone = site.phones[0];
const reviewUrl = site.social.googleReviewUrl;
---

<section class="section section--green" id="contact">
  <div class="container cta">
    <div class="cta__text">
      <span class="eyebrow">Contact & devis gratuit</span>
      <h2>Un projet forestier ou d’entretien&nbsp;? Parlons-en.</h2>
      <p class="lead">
        Devis gratuit et sans engagement. Appelez-nous ou écrivez-nous, nous
        vous répondons rapidement dans tout le secteur de l’Ariège.
      </p>
      <ul class="cta__contacts">
        {site.phones.map((p) => (
          <li>
            <a class="cta__line" href={`tel:${p.tel}`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {p.display}
            </a>
          </li>
        ))}
        <li>
          <a class="cta__line" href={`mailto:${site.email}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,6 12,13 2,6"/></svg>
            {site.email}
          </a>
        </li>
      </ul>
    </div>

    <div class="cta__card">
      <p class="cta__card-title">Appel direct</p>
      <div class="cta__buttons">
        {site.phones.map((p, i) => (
          <a class:list={['btn', i === 0 ? 'btn--primary' : 'btn--white', 'btn--block']} href={`tel:${p.tel}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {p.display}
          </a>
        ))}
        <a class="btn btn--white btn--block" href={`mailto:${site.email}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,6 12,13 2,6"/></svg>
          Envoyer un e-mail
        </a>
        <a class="btn btn--white btn--block" href={site.social.instagramUrl} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          {site.social.instagramHandle}
        </a>
        {reviewUrl && (
          <a class="btn btn--white btn--block" href={reviewUrl} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Laisser un avis Google
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: clamp(1.6rem, 4vw, 3.5rem);
    align-items: center;
  }
  .cta__contacts {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 0.7rem;
  }
  .cta__line {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: #fff;
    font-weight: 700;
    font-size: 1.15rem;
  }
  .cta__line svg {
    width: 22px;
    height: 22px;
    color: var(--yellow-500);
    flex: none;
  }
  .cta__card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-lg);
    padding: 1.6rem;
  }
  .cta__card-title {
    color: #fff;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.82rem;
    margin: 0 0 1rem;
  }
  .cta__buttons {
    display: grid;
    gap: 0.7rem;
  }
  @media (max-width: 780px) {
    .cta {
      grid-template-columns: 1fr;
    }
  }
</style>
