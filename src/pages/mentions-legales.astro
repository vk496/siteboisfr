---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, addressLine } from '../config/site';

const title = `Mentions légales — ${site.name}`;
const description = `Mentions légales du site ${site.url} édité par ${site.legalName}.`;

const legal = site.legal;
// Reste à compléter : le capital social (statuts) et l'hébergeur du site.
const incomplete = [legal.capital, legal.hebergeur].some((v) =>
  v.startsWith('À compléter'),
);
---

<BaseLayout title={title} description={description} path="/mentions-legales">
  <section class="section">
    <div class="container legal">
      <span class="eyebrow">Informations légales</span>
      <h1>Mentions légales</h1>

      {incomplete && (
        <div class="legal-notice" role="note">
          <strong>À compléter&nbsp;:</strong> le capital social et l’hébergeur du
          site restent à renseigner. Modifiez la section <code>legal</code> du
          fichier <code>src/config/site.ts</code>.
        </div>
      )}

      <h2>Éditeur du site</h2>
      <ul class="legal-list">
        <li><strong>Raison sociale :</strong> {site.legalName}</li>
        <li><strong>Forme juridique :</strong> {legal.formeJuridique}</li>
        <li><strong>Siège social :</strong> {addressLine}, {site.address.area}, {site.address.country}</li>
        <li><strong>Téléphone :</strong> {site.phones.map((p) => p.display).join(' / ')}</li>
        <li><strong>E-mail :</strong> {site.email}</li>
        <li><strong>Directeur de la publication :</strong> {legal.gerant}, gérant</li>
        <li><strong>SIREN :</strong> {legal.siren}</li>
        <li><strong>SIRET (siège) :</strong> {legal.siret}</li>
        <li><strong>RCS :</strong> {legal.rcs}</li>
        <li><strong>Code APE :</strong> {legal.ape}</li>
        <li><strong>N° TVA intracommunautaire :</strong> {legal.tva}</li>
        <li><strong>Capital social :</strong> {legal.capital}</li>
        <li><strong>Immatriculation :</strong> {legal.dateImmatriculation}</li>
      </ul>

      <h2>Hébergement</h2>
      <p>{legal.hebergeur}</p>

      <h2>Propriété intellectuelle</h2>
      <p>
        L’ensemble des contenus (textes, logo, photographies) présents sur le
        site {site.url} sont la propriété de {site.legalName}, sauf mention
        contraire. Toute reproduction, représentation ou diffusion, totale ou
        partielle, sans autorisation écrite préalable est interdite.
      </p>

      <h2>Données personnelles</h2>
      <p>
        Le site est un site vitrine qui ne collecte aucune donnée personnelle
        via un formulaire. Les contacts se font par téléphone ou par e-mail à
        l’adresse {site.email}. Conformément au RGPD, vous pouvez exercer vos
        droits d’accès, de rectification et de suppression de vos données en
        nous écrivant à cette adresse.
      </p>

      <h2>Cookies</h2>
      <p>
        Ce site ne dépose pas de cookie de suivi ni de traceur publicitaire.
      </p>

      <p class="legal-back"><a href="/">← Retour à l’accueil</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    max-width: 820px;
  }
  .legal h2 {
    margin-top: 2rem;
    font-size: 1.35rem;
  }
  .legal-notice {
    background: var(--yellow-100);
    border: 1px solid var(--yellow-500);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    margin-block: 1.5rem;
  }
  .legal-notice code {
    background: rgba(0, 0, 0, 0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .legal-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .legal-back {
    margin-top: 2.5rem;
    font-weight: 600;
  }
</style>
