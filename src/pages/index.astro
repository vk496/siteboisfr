---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactCta from '../components/ContactCta.astro';
import { site, addressLine, mapsUrl } from '../config/site';
import { services } from '../data/services';

import heroImg from '../assets/photos/hero-abattage-foret.jpg';
import aboutImg from '../assets/photos/equipe-lbb-bois.jpg';

// Galerie : photos de chantier de LBB BOIS.
import g1 from '../assets/photos/abattage-tronc-geant.jpg';
import g2 from '../assets/photos/bucheron-tronconneuse.jpg';
import g3 from '../assets/photos/debardeuse-neige.jpg';
import g4 from '../assets/photos/tronconnage-grume.jpg';
import g5 from '../assets/photos/coupe-grume.jpg';
import g6 from '../assets/photos/grumes-bord-de-route.jpg';
import g7 from '../assets/photos/abattage-en-foret.jpg';
import g8 from '../assets/photos/entretien-parc-jardin.jpg';
import g9 from '../assets/photos/bois-de-chauffage.jpg';
import g10 from '../assets/photos/abattage-debardage.jpg';
import g11 from '../assets/photos/elagage.jpg';
import g12 from '../assets/photos/equipe-lbb-bois.jpg';

const gallery = [
  { src: g1, alt: 'Bûcheron LBB BOIS devant un tronc de très gros diamètre' },
  { src: g10, alt: 'Abattage d’un arbre lors d’un chantier forestier en Ariège' },
  { src: g4, alt: 'Tronçonnage d’une grume à la tronçonneuse' },
  { src: g9, alt: 'Bois de chauffage en bûches prêt à être livré' },
  { src: g6, alt: 'Grumes de bois alignées en bord de chemin après débardage' },
  { src: g3, alt: 'Débardeuse forestière sur une piste enneigée' },
  { src: g11, alt: 'Élagueur de LBB BOIS harnaché sur un arbre' },
  { src: g2, alt: 'Bûcheron au travail sur un tronc en forêt' },
  { src: g5, alt: 'Coupe d’une grume de gros diamètre' },
  { src: g7, alt: 'Abattage d’un arbre en pleine forêt' },
  { src: g8, alt: 'Tracteur forestier pour le débardage et l’entretien de terrain' },
  { src: g12, alt: 'Équipe de LBB BOIS sur un chantier d’abattage' },
];

const primaryPhone = site.phones[0];

const title = 'LBB BOIS — Abattage, bois de chauffage, élagage & entretien en Ariège';
const description =
  'LBB BOIS, entreprise de travaux forestiers en Ariège (09) : abattage, débardage, bois de chauffage, élagage et entretien de parc et jardin. Devis gratuit à Niaux et alentours.';
---

<BaseLayout title={title} description={description} path="/">
  <!-- ===================== HERO ===================== -->
  <section class="hero" id="accueil">
    <Image class="hero__bg" src={heroImg} alt="" width={1600} height={900} loading="eager" fetchpriority="high" aria-hidden="true" />
    <div class="hero__overlay"></div>
    <div class="container hero__content">
      <span class="hero__eyebrow">Travaux forestiers · Ariège (09)</span>
      <h1>Abattage, bois de chauffage, élagage et entretien d’espaces verts</h1>
      <p class="hero__sub">
        LBB BOIS met son savoir-faire de professionnel de la forêt à votre
        service, à Niaux et dans tout le secteur de l’Ariège. Un travail soigné,
        réalisé en sécurité, du petit chantier à l’exploitation de parcelle.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={`tel:${primaryPhone.tel}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {primaryPhone.display}
        </a>
        <a class="btn btn--white" href="/#services">Découvrir nos services</a>
      </div>
      <ul class="hero__badges">
        <li>Devis gratuit</li>
        <li>Intervention rapide</li>
        <li>Travail en sécurité</li>
      </ul>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Nos prestations</span>
        <h2>4 domaines d’expertise à votre service</h2>
        <p class="lead">
          De l’abattage à l’entretien de vos espaces verts, LBB BOIS vous
          accompagne pour tous vos travaux forestiers et paysagers en Ariège.
        </p>
      </div>
      <div class="grid grid--services">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <!-- ===================== À PROPOS ===================== -->
  <section class="section section--soft" id="a-propos">
    <div class="container about">
      <div class="about__media">
        <Image src={aboutImg} alt="Chantier de débardage réalisé par LBB BOIS en Ariège" width={640} height={480} widths={[320, 480, 640]} sizes="(max-width: 820px) 90vw, 480px" />
      </div>
      <div class="about__text">
        <span class="eyebrow">Qui sommes-nous&nbsp;?</span>
        <h2>LBB BOIS, le bois et la nature comme métier</h2>
        <p>
          Implantée à Niaux, au cœur de l’Ariège, LBB BOIS est une entreprise de
          travaux forestiers et d’entretien d’espaces verts. Passionnés par la
          forêt et la montagne, nous mettons notre expérience et notre matériel
          professionnel au service des particuliers, agriculteurs et
          collectivités du secteur.
        </p>
        <p>
          Abattage, débardage, production de bois de chauffage, élagage ou
          entretien de terrain&nbsp;: chaque chantier est mené avec rigueur, dans
          le respect de vos attentes, de votre terrain et des règles de sécurité.
        </p>
        <ul class="checklist">
          <li>Entreprise locale, connaissance du terrain ariégeois</li>
          <li>Matériel forestier professionnel</li>
          <li>Travail soigné et respectueux de l’environnement</li>
          <li>Interventions même sur terrains difficiles et en pente</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== ZONE D'INTERVENTION ===================== -->
  <section class="section" id="zone">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Zone d’intervention</span>
        <h2>Nous intervenons dans toute l’Ariège</h2>
        <p class="lead">
          Basés à {site.address.city} ({site.address.postalCode}), nous nous
          déplaçons dans tout le département et ses alentours.
        </p>
      </div>
      <ul class="zone-chips">
        {site.serviceArea.map((z) => <li>{z}</li>)}
      </ul>
      <p class="zone-note">
        Votre commune n’est pas dans la liste&nbsp;?
        <a href={`tel:${primaryPhone.tel}`}>Appelez-nous</a>, nous étudions
        chaque demande.
      </p>
    </div>
  </section>

  <!-- ===================== GALERIE ===================== -->
  <section class="section section--soft" id="galerie">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">En images</span>
        <h2>Nos chantiers</h2>
        <p class="lead">Un aperçu de nos réalisations sur le terrain.</p>
      </div>
      <div class="gallery">
        {gallery.map((img) => (
          <figure class="gallery__item">
            <Image src={img.src} alt={img.alt} width={420} height={420} widths={[220, 420]} sizes="(max-width: 640px) 45vw, 260px" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT ===================== -->
  <ContactCta />
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: min(78vh, 640px);
    padding-block: clamp(3rem, 8vw, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      100deg,
      rgba(15, 45, 21, 0.94) 0%,
      rgba(20, 61, 28, 0.86) 45%,
      rgba(20, 61, 28, 0.55) 100%
    );
  }
  .hero__content {
    max-width: 720px;
    color: #fff;
  }
  .hero__eyebrow {
    display: inline-block;
    background: rgba(244, 197, 24, 0.16);
    color: var(--yellow-500);
    border: 1px solid rgba(244, 197, 24, 0.4);
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    margin-bottom: 1.1rem;
  }
  .hero h1 {
    color: #fff;
    margin-bottom: 0.8rem;
  }
  .hero__sub {
    font-size: 1.14rem;
    color: #e4efe4;
    max-width: 60ch;
    margin-bottom: 1.6rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 1.6rem;
  }
  .hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .hero__badges li {
    position: relative;
    padding-left: 1.5rem;
    color: #e4efe4;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .hero__badges li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--yellow-500);
    font-weight: 800;
  }

  /* ---------- À propos ---------- */
  .about {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(1.6rem, 4vw, 3.5rem);
    align-items: center;
  }
  .about__media img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  @media (max-width: 820px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__media {
      max-width: 420px;
    }
  }

  /* ---------- Zone ---------- */
  .zone-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 820px;
  }
  .zone-chips li {
    background: var(--green-50);
    border: 1px solid var(--green-100);
    color: var(--green-800);
    font-weight: 600;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
  }
  .zone-note {
    text-align: center;
    margin-top: 1.6rem;
    color: var(--muted);
  }

  /* ---------- Galerie ---------- */
  .gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.8rem;
  }
  .gallery__item {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 1;
    box-shadow: var(--shadow-sm);
  }
  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .gallery__item:hover img {
    transform: scale(1.06);
  }
  @media (max-width: 680px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
